<Window x:Class="PracticalWork4_Variant3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Практическая работа 4 — вариант 3" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#F2F2F2" Padding="10" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold"
           Text="Практическая работа №4 • WPF • вариант 3"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Margin="6,0,0,0" Padding="14,6" Content="Функция 1" Click="BtnPage1_Click"
            ToolTip="Перейти на 1-ю страницу (формула варианта 3)."/>
                    <Button Margin="6,0,0,0" Padding="14,6" Content="Функция 2" Click="BtnPage2_Click"
            ToolTip="Перейти на 2-ю страницу (кусочная функция c, выбор f(x))."/>
                    <Button Margin="6,0,0,0" Padding="14,6" Content="Функция 3" Click="BtnPage3_Click"
            ToolTip="Перейти на 3-ю страницу (таблица значений + график)."/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
