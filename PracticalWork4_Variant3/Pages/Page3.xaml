<Page x:Class="PracticalWork4_Variant3.Pages.Page3"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
      xmlns:charts="clr-namespace:System.Windows.Forms.DataVisualization.Charting;assembly=System.Windows.Forms.DataVisualization"
      Title="Page3">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Страница 3 — таблица значений и график y(x) (вариант 3)"/>
        <Image Grid.Row="1" Height="170" Margin="0,12,0,0" Stretch="Uniform"
               Source="/PracticalWork4_Variant3;component/Assets/formula3.png"
               ToolTip="Скриншот формулы (вариант 3)."/>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center" Text="x0:" ToolTip="Левая граница отрезка x0."/>
            <TextBox x:Name="TbX0" Grid.Column="1" Height="28" ToolTip="x0"/>

            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="xk:" ToolTip="Правая граница отрезка xk."/>
            <TextBox x:Name="TbXk" Grid.Column="4" Height="28" ToolTip="xk"/>

            <TextBlock Grid.Column="6" VerticalAlignment="Center" Text="dx:" ToolTip="Шаг dx (> 0)."/>
            <TextBox x:Name="TbDx" Grid.Column="7" Height="28" ToolTip="dx"/>

            <TextBlock Grid.Column="9" VerticalAlignment="Center" Text="a:" ToolTip="Параметр a."/>
            <TextBox x:Name="TbA" Grid.Column="10" Height="28" ToolTip="a"/>

            <TextBlock Grid.Column="12" VerticalAlignment="Center" Text="b:" ToolTip="Параметр b."/>
            <TextBox x:Name="TbB" Grid.Column="13" Height="28" ToolTip="b"/>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Width="140" Height="32" Content="Вычислить" Click="BtnCalc_Click"
                    ToolTip="Посчитать значения y на отрезке и построить график."/>
            <Button Width="140" Height="32" Margin="10,0,0,0" Content="Очистить" Click="BtnClear_Click"
                    ToolTip="Очистить ввод, вывод и график."/>
        </StackPanel>

        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="370"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="TbOutput" IsReadOnly="True" TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     ToolTip="Список всех значений x и y."
                     FontFamily="Consolas" FontSize="13"/>

            <Border Grid.Column="2" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4">
                <wfi:WindowsFormsHost x:Name="ChartHost" Margin="6">
                    <charts:Chart x:Name="ChartFx">
                        <charts:Chart.Legends>
                            <charts:Legend />
                        </charts:Chart.Legends>
                    </charts:Chart>
                </wfi:WindowsFormsHost>
            </Border>
        </Grid>
    </Grid>
</Page>
