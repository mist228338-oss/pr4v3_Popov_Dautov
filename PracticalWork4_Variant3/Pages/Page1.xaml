<Page x:Class="PracticalWork4_Variant3.Pages.Page1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Page1">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Страница 1 — расчёт v (вариант 3)"/>
            <Image Grid.Row="1" Height="180" Margin="0,12,0,0" Stretch="Uniform"
                   Source="/PracticalWork4_Variant3;component/Assets/formula1.png"
                   ToolTip="Скриншот формулы (вариант 3)."/>

            <Grid Grid.Row="2" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center" Text="x:" ToolTip="Введите x (вещественное число)."/>
                <TextBox x:Name="TbX" Grid.Column="1" Height="30" Margin="6,0,0,0" ToolTip="x (дробное число)"/>

                <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="y:" ToolTip="Введите y (вещественное число)."/>
                <TextBox x:Name="TbY" Grid.Column="4" Height="30" Margin="6,0,0,0" ToolTip="y (дробное число)"/>

                <TextBlock Grid.Column="6" VerticalAlignment="Center" Text="z:" ToolTip="Введите z (вещественное число)."/>
                <TextBox x:Name="TbZ" Grid.Column="7" Height="30" Margin="6,0,0,0" ToolTip="z (не равно 0)"/>
            </Grid>

            <Grid Grid.Row="3" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="Результат v:" ToolTip="Результат вычисления"/>
                <TextBox x:Name="TbResult" Grid.Column="1" Height="30" Margin="10,0,0,0"
                         IsReadOnly="True" ToolTip="Поле только для чтения"/>
            </Grid>

            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,16,0,0">
                <Button Width="140" Height="34" Content="Вычислить" Click="BtnCalc_Click"
                        ToolTip="Вычислить значение v."/>
                <Button Width="140" Height="34" Margin="10,0,0,0" Content="Очистить" Click="BtnClear_Click"
                        ToolTip="Очистить все поля ввода и результат."/>
            </StackPanel>

            <TextBlock Grid.Row="5" Margin="0,20,0,0" Foreground="#666666" TextWrapping="Wrap">
                Подсказка: в формуле есть дробь 1/(|x − 2y|·z), поэтому z ≠ 0 и x ≠ 2y.
            </TextBlock>
        </Grid>
    </ScrollViewer>
</Page>
