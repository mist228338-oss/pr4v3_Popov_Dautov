<Page x:Class="PracticalWork4_Variant3.Pages.Page2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Page2">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Страница 2 — расчёт c (вариант 3)"/>
            <Image Grid.Row="1" Height="200" Margin="0,12,0,0" Stretch="Uniform"
                   Source="/PracticalWork4_Variant3;component/Assets/formula2.png"
                   ToolTip="Скриншот формулы и условий (вариант 3)."/>

            <Grid Grid.Row="2" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center" Text="x:" ToolTip="Введите x (вещественное число)."/>
                <TextBox x:Name="TbX" Grid.Column="1" Height="30" Margin="6,0,0,0" ToolTip="x"/>

                <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="y:" ToolTip="Введите y (вещественное число)."/>
                <TextBox x:Name="TbY" Grid.Column="4" Height="30" Margin="6,0,0,0" ToolTip="y"/>
            </Grid>

            <GroupBox Grid.Row="3" Header="Выбор f(x)" Margin="0,14,0,0" ToolTip="Выберите функцию f(x), которая используется в формуле">
                <StackPanel Orientation="Horizontal" Margin="10">
                    <RadioButton x:Name="RbSh" Content="sh(x)" IsChecked="True" Margin="0,0,16,0"
                                 ToolTip="f(x) = sh(x) (гиперболический синус)"/>
                    <RadioButton x:Name="RbX2" Content="x²" Margin="0,0,16,0" ToolTip="f(x) = x²"/>
                    <RadioButton x:Name="RbExp" Content="eˣ" ToolTip="f(x) = e^x"/>
                </StackPanel>
            </GroupBox>

            <Grid Grid.Row="4" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="Результат c:"/>
                <TextBox x:Name="TbResult" Grid.Column="1" Height="30" Margin="10,0,0,0"
                         IsReadOnly="True" ToolTip="Поле только для чтения"/>
            </Grid>

            <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,16,0,0">
                <Button Width="140" Height="34" Content="Вычислить" Click="BtnCalc_Click"
                        ToolTip="Вычислить значение c."/>
                <Button Width="140" Height="34" Margin="10,0,0,0" Content="Очистить" Click="BtnClear_Click"
                        ToolTip="Очистить поля."/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
